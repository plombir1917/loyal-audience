{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
        {
          "include": "frontend/public/**/*",
          "watchAssets": true,
          "outDir": "dist/src"
      },
        {
          "include": "admin/components/**/*.jsx",
          "watchAssets": true,
          "outDir": "dist/src"
      },
        {
          "include": "public/**/*",
          "watchAssets": true,
          "outDir": "dist/src"
      }
    ]
  }
}
