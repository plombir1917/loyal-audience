# Сервисный токен доступа к API ВКонтакте
VK_TOKEN=
# Уровень логирования: debug | info | warn | error
LOG_LEVEL=info

# Подключение к Postgres (общий с admin-panel).
# Локально: localhost; в docker-compose: postgres
DATABASE_URL=

# Классификатор тональности (OpenAI-совместимый chat/completions API).
# Реальная модель — основной классификатор; словарный — автоматический fallback
# при сбое модели. Если LLM_BASE_URL пуст — используется только словарный.
# OpenAI:     LLM_BASE_URL=https://api.openai.com/v1   LLM_MODEL=gpt-4o-mini
# OpenRouter: LLM_BASE_URL=https://openrouter.ai/api/v1 LLM_MODEL=openai/gpt-4o-mini
# Ollama:     LLM_BASE_URL=http://localhost:11434/v1    LLM_MODEL=qwen2.5:7b (без ключа)
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openrouter/owl-alpha
LLM_API_KEY=

# Параметры сбора.
REGION_NAME=Чувашская Республика
# Доп. поисковые запросы на каждый город (через запятую) сверх имени города.
# Больше затравок — больше охват сообществ (результаты дедуплицируются по id),
# но и больше запросов к API. Пусто — встроенный список по умолчанию.
SEARCH_KEYWORDS=
# Нижняя граница даты публикаций (YYYY-MM-DD). По умолчанию — 1 января текущего года.
COLLECT_SINCE=
# 0 — без ограничения (максимальный охват: все посты сообщества с COLLECT_SINCE).
MAX_POSTS_PER_GROUP=0
MAX_COMMENTS_PER_POST=100
# Ограничение числа сообществ за прогон (0 — без ограничения; удобно для smoke).
MAX_COMMUNITIES=0
# true — пропускать сообщество целиком, если оно уже в БД (быстрые повторные
# прогоны, но новые посты в известных сообществах не подхватятся). По умолчанию
# false: сообщества сканируются, пропускаются лишь готовые комментарии/лайки.
SKIP_EXISTING_COMMUNITIES=false
# true — повторно распарсить и переобработать уже сохранённые сущности
# (сообщества, посты, комментарии, лайки, реакции) и заново классифицировать
# тональности, игнорируя все пропуски. Перекрывает SKIP_EXISTING_COMMUNITIES.
# Медленнее, но обновляет данные; upsert'ы идемпотентны (дублей не будет).
REPARSE_EXISTING=false
# Лимит запросов к API ВК в секунду (сервисный токен ≈ 3).
VK_RATE_LIMIT=3
# Число параллельных обращений к классификатору тональности (постов и
# комментариев). Больше — быстрее, но легче упереться в лимиты LLM (429).
CLASSIFY_CONCURRENCY=8

# Ядро аудитории: is_core = (лайков > LIKE_THRESHOLD) [CORE_COMBINE]
# (позитивных комментариев > COMMENT_THRESHOLD). CORE_COMBINE = and | or
# (and — «умножение» булевых из ТЗ; or — дизъюнкция). Пороги тюнятся по статистике.
LIKE_THRESHOLD=1
COMMENT_THRESHOLD=1
CORE_COMBINE=and
