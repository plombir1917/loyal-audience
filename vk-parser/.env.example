# Сервисный токен доступа к API ВКонтакте
VK_TOKEN=
# Уровень логирования: debug | info | warn | error
LOG_LEVEL=info

# Подключение к Postgres (общий с admin-panel).
# Локально: localhost; в docker-compose: postgres
DATABASE_URL=

# Классификатор тональности (OpenAI-совместимый chat/completions API).
# Если LLM_BASE_URL пуст — используется встроенный словарный классификатор.
# Примеры base url: http://localhost:11434/v1 (Ollama), https://openrouter.ai/api/v1
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=

# Параметры сбора.
REGION_NAME=Чувашская Республика
# Нижняя граница даты публикаций (YYYY-MM-DD). По умолчанию — 1 января текущего года.
COLLECT_SINCE=
MAX_POSTS_PER_GROUP=100
MAX_COMMENTS_PER_POST=100
# Ограничение числа сообществ за прогон (0 — без ограничения; удобно для smoke).
MAX_COMMUNITIES=0
# Лимит запросов к API ВК в секунду (сервисный токен ≈ 3).
VK_RATE_LIMIT=3
