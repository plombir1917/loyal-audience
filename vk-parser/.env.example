# Сервисный токен доступа к API ВКонтакте
VK_TOKEN=
# Уровень логирования: debug | info | warn | error
LOG_LEVEL=info

# Подключение к Postgres (общий с admin-panel).
# Локально: localhost; в docker-compose: postgres
DATABASE_URL=

# Классификатор тональности (OpenAI-совместимый chat/completions API).
# Реальная модель — основной классификатор; словарный — автоматический fallback
# при сбое модели. Если LLM_BASE_URL пуст — используется только словарный.
# OpenAI:     LLM_BASE_URL=https://api.openai.com/v1   LLM_MODEL=gpt-4o-mini
# OpenRouter: LLM_BASE_URL=https://openrouter.ai/api/v1 LLM_MODEL=openai/gpt-4o-mini
# Ollama:     LLM_BASE_URL=http://localhost:11434/v1    LLM_MODEL=qwen2.5:7b (без ключа)
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openrouter/owl-alpha
LLM_API_KEY=

# Параметры сбора.
REGION_NAME=Чувашская Республика
# Нижняя граница даты публикаций (YYYY-MM-DD). По умолчанию — 1 января текущего года.
COLLECT_SINCE=
MAX_POSTS_PER_GROUP=100
MAX_COMMENTS_PER_POST=100
# Ограничение числа сообществ за прогон (0 — без ограничения; удобно для smoke).
MAX_COMMUNITIES=0
# true — пропускать сообщество целиком, если оно уже в БД (быстрые повторные
# прогоны, но новые посты в известных сообществах не подхватятся). По умолчанию
# false: сообщества сканируются, пропускаются лишь готовые комментарии/лайки.
SKIP_EXISTING_COMMUNITIES=false
# Лимит запросов к API ВК в секунду (сервисный токен ≈ 3).
VK_RATE_LIMIT=3
